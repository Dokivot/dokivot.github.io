---
interface Props {
  href: string;
  title: string;
  description?: string;
  meta?: string;
}

const { href, title, description, meta } = Astro.props;
---

<a
  href={href}
  class="block rounded border border-[var(--color-border-light)] bg-[var(--color-bg-tertiary)] p-6 no-underline transition-colors duration-150 hover:border-[var(--color-border)]"
>
  <h3 class="text-lg font-semibold text-[var(--color-text)]" style="font-family: var(--font-heading);">
    {title}
  </h3>
  {meta && (
    <p class="mt-1 text-sm text-[var(--color-text-secondary)]">{meta}</p>
  )}
  {description && (
    <p class="mt-3 text-sm leading-relaxed text-[var(--color-text-secondary)]">
      {description}
    </p>
  )}
</a>
