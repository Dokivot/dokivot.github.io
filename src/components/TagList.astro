---
interface Props {
  tags: string[];
  linkPrefix?: string;
}

const { tags, linkPrefix } = Astro.props;
const prefix = linkPrefix ?? '';
---

{
  tags.length > 0 && (
    <span class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <a
          href={`${prefix}?tag=${encodeURIComponent(tag)}`}
          class="text-sm text-[var(--color-text-secondary)] no-underline transition-colors duration-150 hover:text-[var(--color-accent)]"
        >
          #{tag}
        </a>
      ))}
    </span>
  )
}
