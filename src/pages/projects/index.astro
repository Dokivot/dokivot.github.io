---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
projects.sort((a, b) => a.data.order - b.data.order);

const statusLabel: Record<string, string> = {
  active: 'Active',
  completed: 'Completed',
  archived: 'Archived',
};
---

<BaseLayout title="Projects">
  <div class="mx-auto max-w-4xl px-4 py-16">
    <h1 class="text-h1 font-bold" style="font-family: var(--font-heading);">Projects</h1>
    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      {projects.length === 0 ? (
        <p class="col-span-full text-[var(--color-text-secondary)]">No projects yet.</p>
      ) : (
        projects.map((project) => (
          <Card
            href={`/projects/${project.id}/`}
            title={project.data.title}
            description={project.data.description}
            meta={`${statusLabel[project.data.status]} · ${project.data.tech_stack.slice(0, 3).join(', ')}`}
          />
        ))
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .text-h1 { font-size: 2rem; line-height: 1.3; }
</style>
