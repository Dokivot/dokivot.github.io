---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaturityBadge from '../../components/MaturityBadge.astro';
import TagList from '../../components/TagList.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../lib/utils';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({ params: { slug: note.id } }));
}

const { slug } = Astro.params;
const notes = await getCollection('notes');
const note = notes.find((n) => n.id === slug);

if (!note) return Astro.redirect('/404');

const { Content } = await render(note);

const relatedPosts = note.data.related_posts?.length
  ? (await getCollection('blog')).filter((p) => !p.data.draft && note.data.related_posts?.includes(p.id))
  : [];

const relatedNotesList = note.data.related_notes?.length
  ? notes.filter((n) => note.data.related_notes?.includes(n.id))
  : [];
---

<BaseLayout title={note.data.title}>
  <article class="mx-auto max-w-[65ch] px-4 py-16">
    <header class="mb-8">
      <div class="flex items-center gap-3">
        <h1 class="text-h1 font-bold" style="font-family: var(--font-heading);">
          {note.data.title}
        </h1>
        <MaturityBadge maturity={note.data.maturity} />
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-4 text-sm text-[var(--color-text-secondary)]">
        <span>Created {formatDate(note.data.created)}</span>
        <span>·</span>
        <span>Updated {formatDate(note.data.updated)}</span>
      </div>
      <div class="mt-3">
        <TagList tags={note.data.tags} linkPrefix="/notes" />
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
    {(relatedPosts.length > 0 || relatedNotesList.length > 0) && (
      <footer class="mt-12 border-t border-[var(--color-border-light)] pt-8">
        {relatedPosts.length > 0 && (
          <div class="mb-6">
            <h2 class="text-lg font-semibold text-[var(--color-text)]" style="font-family: var(--font-heading);">
              Related Posts
            </h2>
            <ul class="mt-2 space-y-1">
              {relatedPosts.map((p) => (
                <li>
                  <a href={`/blog/${p.id}/`} class="text-sm text-[var(--color-accent)]">
                    {p.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        {relatedNotesList.length > 0 && (
          <div>
            <h2 class="text-lg font-semibold text-[var(--color-text)]" style="font-family: var(--font-heading);">
              Related Notes
            </h2>
            <ul class="mt-2 space-y-1">
              {relatedNotesList.map((n) => (
                <li>
                  <a href={`/notes/${n.id}/`} class="text-sm text-[var(--color-accent)]">
                    {n.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </footer>
    )}
  </article>
</BaseLayout>

