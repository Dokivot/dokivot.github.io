---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL_LINKS } from '../lib/constants';
import { Mail, Rss, GraduationCap } from '@lucide/astro';
import SocialIcon from '../components/SocialIcon.astro';
---

<BaseLayout title="About">
  <div class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="text-h1 font-bold" style="font-family: var(--font-heading);">About</h1>
    <div class="prose mt-8">
      <p>
        I'm a graduate student focused on large language model training.
        This site is my quiet knowledge repository — a place to think through
        hard technical problems, document experiments, and share what I learn.
      </p>
    </div>

    <div class="mt-12 border-t border-[var(--color-border-light)] pt-8">
      <h2 class="text-h2" style="font-family: var(--font-heading);">Find Me</h2>
      <div class="mt-4 flex flex-wrap items-center gap-4">
        <a
          href={SOCIAL_LINKS.github}
          class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)] no-underline transition-colors duration-150 hover:text-[var(--color-accent)]"
          target="_blank"
          rel="noopener noreferrer"
        >
          <SocialIcon name="github" />
          GitHub
        </a>
        <a
          href={SOCIAL_LINKS.twitter}
          class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)] no-underline transition-colors duration-150 hover:text-[var(--color-accent)]"
          target="_blank"
          rel="noopener noreferrer"
        >
          <SocialIcon name="twitter" />
          Twitter
        </a>
        <a
          href={SOCIAL_LINKS.scholar}
          class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)] no-underline transition-colors duration-150 hover:text-[var(--color-accent)]"
          target="_blank"
          rel="noopener noreferrer"
        >
          <GraduationCap size={18} />
          Google Scholar
        </a>
        <a
          href={SOCIAL_LINKS.email}
          class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)] no-underline transition-colors duration-150 hover:text-[var(--color-accent)]"
        >
          <Mail size={18} />
          Email
        </a>
        <a
          href="/blog/rss.xml"
          class="flex items-center gap-2 text-sm text-[var(--color-text-secondary)] no-underline transition-colors duration-150 hover:text-[var(--color-accent)]"
        >
          <Rss size={18} />
          RSS
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
