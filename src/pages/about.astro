---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="text-h1 font-bold" style="font-family: var(--font-heading);">About</h1>
    <div class="prose mt-8">
      <p>
        I'm a graduate student focused on large language model training.
        This site is my quiet knowledge repository — a place to think through
        hard technical problems, document experiments, and share what I learn.
      </p>
      <p>
        More details coming soon.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .text-h1 {
    font-size: 2rem;
    line-height: 1.3;
  }
</style>
