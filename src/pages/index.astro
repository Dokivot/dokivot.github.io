---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import MaturityBadge from '../components/MaturityBadge.astro';
import { SITE } from '../lib/constants';
import { getCollection } from 'astro:content';
import { formatDate } from '../lib/utils';

const blogPosts = await getCollection('blog', ({ data }) => !data.draft);
blogPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const recentPosts = blogPosts.slice(0, 3);

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);
const featuredProjects = allProjects.filter((p) => p.data.status !== 'archived').slice(0, 3);

const allNotes = await getCollection('notes');
allNotes.sort((a, b) => b.data.updated.getTime() - a.data.updated.getTime());
const recentNotes = allNotes.slice(0, 5);
---

<BaseLayout>
  <section
    class="relative overflow-hidden px-4 pb-12 pt-24 sm:pt-32"
    style="background: linear-gradient(180deg, var(--color-bg), color-mix(in srgb, var(--color-accent) 3%, transparent));"
  >
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-hero font-bold" style="font-family: var(--font-heading);">
        {SITE.title}
      </h1>
      <p class="mt-4 text-lg" style="color: var(--color-text-secondary);">
        {SITE.description}
      </p>
      <div class="mt-8 flex items-center justify-center gap-4">
        <a
          href="/blog"
          class="rounded-md px-5 py-2.5 text-sm font-medium text-white no-underline transition-colors duration-150 hover:text-white"
          style="background-color: var(--color-accent);"
        >
          Read the Blog
        </a>
        <a
          href="/about"
          class="rounded-md border px-5 py-2.5 text-sm font-medium no-underline transition-colors duration-150"
          style="border-color: var(--color-border); color: var(--color-text-secondary);"
        >
          About Me
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-lg font-semibold" style="font-family: var(--font-heading);">
            Recent Posts
          </h2>
          {blogPosts.length > 3 && (
            <a href="/blog" class="text-sm text-[var(--color-accent)] no-underline hover:underline">
              View all &rarr;
            </a>
          )}
        </div>
        {recentPosts.length === 0 ? (
          <p class="text-sm text-[var(--color-text-secondary)]">No posts yet.</p>
        ) : (
          <div class="space-y-3">
            {recentPosts.map((post) => (
              <Card
                href={`/blog/${post.id}/`}
                title={post.data.title}
                description={post.data.description}
                meta={formatDate(post.data.date)}
              />
            ))}
          </div>
        )}
      </div>

      <div>
        <div class="mb-6 flex items-center justify-between">
          <h2 class="text-lg font-semibold" style="font-family: var(--font-heading);">
            Featured Projects
          </h2>
          {allProjects.length > 3 && (
            <a href="/projects" class="text-sm text-[var(--color-accent)] no-underline hover:underline">
              View all &rarr;
            </a>
          )}
        </div>
        {featuredProjects.length === 0 ? (
          <p class="text-sm text-[var(--color-text-secondary)]">No projects yet.</p>
        ) : (
          <div class="space-y-3">
            {featuredProjects.map((project) => (
              <Card
                href={`/projects/${project.id}/`}
                title={project.data.title}
                description={project.data.description}
                meta={project.data.tech_stack.slice(0, 3).join(', ')}
              />
            ))}
          </div>
        )}
      </div>
    </div>

    <div class="mt-12">
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-lg font-semibold" style="font-family: var(--font-heading);">
          Recent Notes
        </h2>
        {allNotes.length > 5 && (
          <a href="/notes" class="text-sm text-[var(--color-accent)] no-underline hover:underline">
            View all &rarr;
          </a>
        )}
      </div>
      {recentNotes.length === 0 ? (
        <p class="text-sm text-[var(--color-text-secondary)]">No notes yet.</p>
      ) : (
        <div class="space-y-2">
          {recentNotes.map((note) => (
            <div class="flex items-center justify-between rounded border border-[var(--color-border-light)] bg-[var(--color-bg-tertiary)] px-4 py-3">
              <a
                href={`/notes/${note.id}/`}
                class="text-sm font-medium text-[var(--color-text)] no-underline transition-colors duration-150 hover:text-[var(--color-accent)]"
              >
                {note.data.title}
              </a>
              <div class="flex items-center gap-3">
                <span class="text-xs text-[var(--color-text-secondary)]">{formatDate(note.data.updated)}</span>
                <MaturityBadge maturity={note.data.maturity} />
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .text-hero {
    font-size: 2.5rem;
    line-height: 1.2;
  }
</style>
