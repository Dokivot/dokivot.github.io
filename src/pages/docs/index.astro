---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
docs.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Docs">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="flex gap-8">
      <aside class="hidden w-56 shrink-0 lg:block">
        <nav class="sticky top-20 space-y-1">
          <h2 class="text-sm font-semibold text-[var(--color-text-secondary)]">Documentation</h2>
          {docs.map((doc) => (
            <a
              href={`/docs/${doc.id}/`}
              class="block rounded px-3 py-1.5 text-sm text-[var(--color-text-secondary)] no-underline transition-colors duration-150 hover:bg-[var(--color-bg-tertiary)] hover:text-[var(--color-text)]"
            >
              {doc.data.title}
            </a>
          ))}
        </nav>
      </aside>
      <main class="min-w-0 flex-1">
        <h1 class="text-h1 font-bold" style="font-family: var(--font-heading);">Documentation</h1>
        <div class="prose mt-8">
          <p class="text-[var(--color-text-secondary)]">
            Technical guides, tutorials, and reference documentation.
          </p>
          {docs.length === 0 ? (
            <p class="text-[var(--color-text-secondary)]">No docs yet.</p>
          ) : (
            <ul>
              {docs.map((doc) => (
                <li>
                  <a href={`/docs/${doc.id}/`}>{doc.data.title}</a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .text-h1 { font-size: 2rem; line-height: 1.3; }
</style>
