---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagList from '../../components/TagList.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((doc) => ({ params: { slug: doc.id } }));
}

const { slug } = Astro.params;
const docs = await getCollection('docs');
docs.sort((a, b) => a.data.order - b.data.order);
const doc = docs.find((d) => d.id === slug);

if (!doc) return Astro.redirect('/404');

const { Content } = await render(doc);
---

<BaseLayout title={doc.data.title}>
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="flex gap-8">
      <aside class="hidden w-56 shrink-0 lg:block">
        <nav class="sticky top-20 space-y-1">
          <h2 class="text-sm font-semibold text-[var(--color-text-secondary)]">Documentation</h2>
          {docs.map((d) => (
            <a
              href={`/docs/${d.id}/`}
              class={`block rounded px-3 py-1.5 text-sm no-underline transition-colors duration-150 ${
                d.id === slug
                  ? 'bg-[var(--color-bg-tertiary)] font-medium text-[var(--color-accent)]'
                  : 'text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-tertiary)] hover:text-[var(--color-text)]'
              }`}
            >
              {d.data.title}
            </a>
          ))}
        </nav>
      </aside>
      <main class="min-w-0 flex-1">
        <article class="max-w-[65ch]">
          <header class="mb-8">
            <h1 class="text-h1 font-bold" style="font-family: var(--font-heading);">
              {doc.data.title}
            </h1>
            <div class="mt-4">
              <TagList tags={doc.data.tags} linkPrefix="/docs" />
            </div>
          </header>
          <div class="prose">
            <Content />
          </div>
        </article>
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .text-h1 { font-size: 2rem; line-height: 1.3; }
</style>
