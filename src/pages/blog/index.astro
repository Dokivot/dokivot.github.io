---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import TagList from '../../components/TagList.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/utils';

const tag = Astro.url.searchParams.get('tag');
const posts = await getCollection('blog', ({ data }) => {
  if (data.draft) return false;
  if (tag) return data.tags.includes(tag);
  return true;
});
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const pageTitle = tag ? `Blog: #${tag}` : 'Blog';
---

<BaseLayout title={pageTitle}>
  <div class="mx-auto max-w-2xl px-4 py-16">
    <h1 class="text-h1 font-bold" style="font-family: var(--font-heading);">Blog</h1>
    {tag && (
      <p class="mt-2 text-sm text-[var(--color-text-secondary)]">
        Filtered by tag: <a href="/blog" class="text-[var(--color-accent)]">clear</a>
      </p>
    )}
    <div class="mt-8 space-y-4">
      {posts.length === 0 ? (
        <p class="text-[var(--color-text-secondary)]">No posts yet.</p>
      ) : (
        posts.map((post) => (
          <Card
            href={`/blog/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            meta={formatDate(post.data.date)}
          />
        ))
      )}
    </div>
  </div>
</BaseLayout>

