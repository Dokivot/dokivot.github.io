---
import '../styles/global.css';
import { SITE, NAV_ITEMS, SOCIAL_LINKS } from '../lib/constants';
import {
  FileText,
  StickyNote,
  FolderGit2,
  BookOpen,
  User,
  Mail,
  Rss,
  Sun,
  Moon,
  Menu,
} from '@lucide/astro';
import SocialIcon from '../components/SocialIcon.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.title}` : SITE.title;
const pageDescription = description ?? SITE.description;

const iconMap: Record<string, typeof FileText> = {
  FileText,
  StickyNote,
  FolderGit2,
  BookOpen,
  User,
};

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, SITE.url).href} />
    {
      ogImage && (
        <meta property="og:image" content={new URL(ogImage, SITE.url).href} />
      )
    }
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Blog RSS" href="/blog/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="Notes RSS" href="/notes/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..700;1,14..32,400..700&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400..700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--color-bg)] text-[var(--color-text)]">
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        if (
          stored === 'dark' ||
          (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)
        ) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>

    <nav class="sticky top-0 z-50 h-14 border-b border-[var(--color-border-light)] bg-[var(--color-bg)]/80 backdrop-blur-[8px]">
      <div class="mx-auto flex h-full max-w-6xl items-center justify-between px-4">
        <a
          href="/"
          class="font-[family-name:var(--font-heading)] text-lg font-semibold text-[var(--color-text)] no-underline hover:text-[var(--color-accent)]"
        >
          {SITE.title}
        </a>
        <div class="hidden md:flex items-center gap-1">
          {
            NAV_ITEMS.map((item) => {
              const Icon = iconMap[item.icon];
              const isActive = currentPath.startsWith(item.href);
              return (
                <a
                  href={item.href}
                  class={`flex items-center gap-1.5 rounded px-2.5 py-1.5 text-sm font-medium no-underline transition-colors duration-150 ${
                    isActive
                      ? 'text-[var(--color-accent)]'
                      : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]'
                  }`}
                >
                  <Icon size={16} />
                  <span class="hidden sm:inline">{item.label}</span>
                </a>
              );
            })
          }
          <button
            id="theme-toggle"
            class="ml-2 flex items-center rounded p-1.5 text-[var(--color-text-secondary)] transition-colors duration-150 hover:text-[var(--color-accent)]"
            aria-label="Toggle dark mode"
          >
            <Sun size={16} class="dark:hidden" />
            <Moon size={16} class="hidden dark:block" />
          </button>
        </div>

        <div class="flex md:hidden items-center gap-1">
          <button
            id="theme-toggle-mobile"
            class="flex items-center rounded p-1.5 text-[var(--color-text-secondary)] transition-colors duration-150 hover:text-[var(--color-accent)]"
            aria-label="Toggle dark mode"
          >
            <Sun size={16} class="dark:hidden" />
            <Moon size={16} class="hidden dark:block" />
          </button>
          <button
            id="hamburger"
            class="flex items-center rounded p-1.5 text-[var(--color-text-secondary)] transition-colors duration-150 hover:text-[var(--color-accent)]"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <Menu size={20} />
          </button>
        </div>

      </div>
    </nav>

    <div
      id="mobile-menu"
      class="fixed inset-x-0 top-14 z-40 hidden border-b border-[var(--color-border-light)] bg-[var(--color-bg)]/95 backdrop-blur-[8px] md:hidden"
    >
      <div class="mx-auto max-w-6xl px-4 py-4">
        {
          NAV_ITEMS.map((item) => {
            const Icon = iconMap[item.icon];
            const isActive = currentPath.startsWith(item.href);
            return (
              <a
                href={item.href}
                class={`flex items-center gap-2 rounded px-3 py-2.5 text-sm font-medium no-underline transition-colors duration-150 ${
                  isActive
                    ? 'text-[var(--color-accent)]'
                    : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent)]'
                }`}
              >
                <Icon size={16} />
                {item.label}
              </a>
            );
          })
        }
      </div>
    </div>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border-light)] py-8">
      <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-4 sm:flex-row sm:justify-between">
        <p class="text-sm text-[var(--color-text-secondary)]">
          &copy; {new Date().getFullYear()} {SITE.author}
        </p>
        <div class="flex items-center gap-4">
          <a
            href={SOCIAL_LINKS.github}
            aria-label="GitHub"
            class="text-[var(--color-text-secondary)] transition-colors duration-150 hover:text-[var(--color-accent)]"
            target="_blank"
            rel="noopener noreferrer"
          >
            <SocialIcon name="github" />
          </a>
          <a
            href={SOCIAL_LINKS.email}
            aria-label="Email"
            class="text-[var(--color-text-secondary)] transition-colors duration-150 hover:text-[var(--color-accent)]"
          >
            <Mail size={18} />
          </a>
          <a
            href="/blog/rss.xml"
            aria-label="RSS"
            class="text-[var(--color-text-secondary)] transition-colors duration-150 hover:text-[var(--color-accent)]"
          >
            <Rss size={18} />
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      function toggleTheme() {
        document.documentElement.classList.toggle('dark');
        localStorage.setItem(
          'theme',
          document.documentElement.classList.contains('dark') ? 'dark' : 'light',
        );
      }
      document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
      document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');
      if (hamburger && mobileMenu) {
        hamburger.addEventListener('click', () => {
          const expanded = hamburger.getAttribute('aria-expanded') === 'true';
          hamburger.setAttribute('aria-expanded', String(!expanded));
          mobileMenu.classList.toggle('hidden');
        });
        mobileMenu.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            hamburger.setAttribute('aria-expanded', 'false');
            mobileMenu.classList.add('hidden');
          });
        });
      }
    </script>
  </body>
</html>
